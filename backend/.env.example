# Klarix — Environment Variables
# Copy this file to .env and fill in your values.

# ── App ──────────────────────────────────────────
APP_NAME=Klarix
DEBUG=false
DATA_DIR=./data

# ── Database ─────────────────────────────────────
# SQLite — file lives inside DATA_DIR. No changes needed unless you want a custom path.
DATABASE_URL=sqlite+aiosqlite:///./data/klarix.db

# ── GitHub ───────────────────────────────────────
# Required for private repos. Also raises API rate limit from 60 → 5,000 req/hr.
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# ── LLM (default provider) ───────────────────────
# These are the fallback defaults. Users can override per-session via the settings UI.
LLM_PROVIDER=anthropic        # anthropic | openai | ollama | custom
LLM_API_KEY=                  # Your Anthropic or OpenAI API key
LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=                 # Only for Ollama/custom: e.g. http://localhost:11434

# ── Rate Limit Protection ────────────────────────
# Set your LLM plan's token-per-minute limit for the 95% hard-stop to work.
# Set to 0 to disable rate limit tracking (recommended for local models like Ollama).
LLM_RATE_LIMIT_TPM=0

# ── Embeddings ───────────────────────────────────
# Runs locally via sentence-transformers — no API key needed.
EMBEDDING_MODEL=all-MiniLM-L6-v2
