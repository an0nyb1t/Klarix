# GitChat — Environment Variables
# Copy this file to .env and fill in your values.
#
# For Docker:     cp .env.example .env && docker compose up --build
# For local dev:  cp .env.example backend/.env

# ── GitHub ───────────────────────────────────────
# Required for private repos. Also raises API rate limit from 60 → 5,000 req/hr.
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# ── LLM (default provider) ───────────────────────
# Users can override per-session via the settings UI.
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=

# ── Rate Limit Protection ────────────────────────
# Set your LLM plan's token-per-minute limit. 0 = disabled (for local models).
LLM_RATE_LIMIT_TPM=0

# ── Embeddings ───────────────────────────────────
# Runs locally — no API key needed.
EMBEDDING_MODEL=all-MiniLM-L6-v2
